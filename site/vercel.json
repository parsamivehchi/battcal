{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/battcal", "permanent": false }
  ],
  "rewrites": [
    { "source": "/battcal", "destination": "/index.html" },
    { "source": "/battcal/api/:path*", "destination": "/api/:path*" },
    { "source": "/battcal/:path*", "destination": "/:path*" }
  ],
  "headers": [
    {
      "source": "/battcal/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
