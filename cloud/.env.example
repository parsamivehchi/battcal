# battcal cloud mirror - required env (set on the Vercel project, production + preview).
# All personal values are env-driven; nothing here is baked into the public repo.

# Session cookie signing secret (HS256). Generate FRESH per app: openssl rand -base64 48
SESSION_SECRET=

# prsa.me OIDC identity provider (this app is a relying party; client_id "battcal").
# Registered via the hub's scripts/register-oauth-client.mjs; the redirect URI carries the
# /battcal basePath (the app is path-mounted at mivehchi.dev/battcal).
PRSA_OIDC_ISSUER=https://prsa.me
PRSA_OIDC_CLIENT_ID=battcal
PRSA_OIDC_CLIENT_SECRET=
PRSA_OIDC_REDIRECT_URI=https://mivehchi.dev/battcal/auth/callback

# Owner allowlist (comma-separated). Server-only (NOT NEXT_PUBLIC).
OWNER_EMAILS=

# Supabase (the battcal_* tables the Mac's uploader pushes to). Service-role key, server-only.
BATTCAL_SUPABASE_URL=
BATTCAL_SUPABASE_SERVICE_KEY=

# Local dev note: with no SESSION_SECRET and NODE_ENV=development the gate is OPEN (stub/dev
# data only); production fails closed.
